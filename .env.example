# Crosstalk environment variables
# Copy to .env and fill in (never commit .env!)

# ── Provider API keys (set at least one) ─────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Transcript signing (optional) ────────────────────────────────────────────
# Encrypt the persisted signing key at rest (ChaCha20-Poly1305 + Argon2id).
CROSSTALK_SIGNING_PASSPHRASE=
# Pin the signing identity out-of-band; a mismatched key aborts on load.
CROSSTALK_EXPECTED_PUBKEY=

# ── Paths & limits (optional; XDG defaults used otherwise) ───────────────────
# CROSSTALK_MEMORY_DIR=
# CROSSTALK_PROJECT_ROOT=
# CROSSTALK_RPM=60
